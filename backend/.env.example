# ─── Application ───
APP_NAME=BookMyBox
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ─── Server ───
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ─── Database ───
DATABASE_URL=postgresql+asyncpg://bookmybox:bookmybox_secret@localhost:5432/bookmybox
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_ECHO=false

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# ─── JWT ───
JWT_SECRET_KEY=change-me-to-a-random-64-char-string-in-production
JWT_REFRESH_SECRET_KEY=change-me-to-another-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── OTP ───
OTP_EXPIRY_SECONDS=300
OTP_LENGTH=6
OTP_MOCK_CODE=123456

# ─── SMTP (Email) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@bookmybox.com
SMTP_FROM_NAME=BookMyBox

# ─── Storage (S3-Compatible) ───
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage
S3_BUCKET_NAME=bookmybox-assets
S3_REGION=ap-south-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT_URL=

# ─── Celery ───
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── Sentry ───
SENTRY_DSN=

# ─── Rate Limiting ───
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10

# ─── Google OAuth ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
